# Copia in .env.local e compila i valori
# NON committare mai .env.local su Git

# NextAuth
AUTH_SECRET=cambia-con-openssl-rand-hex-32
AUTH_URL=http://localhost:3000

# Google OAuth (opzionale - ottienilo da console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (email) - ottienilo da resend.com (piano free: 3k email/mese)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Dashboard Gatto <noreply@tuodominio.com>

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SHARE_SECRET=cambia-con-openssl-rand-hex-32

# R2 public URL (dopo aver abilitato accesso pubblico su Cloudflare)
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# Solo per drizzle-kit (generate migrazioni) - non serve a runtime
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=
